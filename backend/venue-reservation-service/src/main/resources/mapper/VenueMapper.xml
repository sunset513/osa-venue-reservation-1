<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="tw.edu.ncu.osa.venue_reservation_service.mapper.VenueMapper">

    <!-- ========================================== -->
    <!-- ResultMap 定義 - 場地資料映射 -->
    <!-- ========================================== -->

    <resultMap id="VenueDetailMap" type="tw.edu.ncu.osa.venue_reservation_service.model.entity.Venue">
        <id property="id" column="id" />
        <result property="unitId" column="unit_id" />
        <result property="name" column="name" />
        <result property="capacity" column="capacity" />
        <result property="description" column="description" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <!-- ========================================== -->
    <!-- 查詢操作 -->
    <!-- ========================================== -->

    <select id="selectVenuesByUnitId" resultMap="VenueDetailMap">
        SELECT
            v.id,
            v.unit_id,
            v.name,
            v.capacity,
            v.description,
            v.created_at,
            v.updated_at
        FROM venues v
        WHERE v.unit_id = #{unitId}
        ORDER BY v.id ASC
    </select>

    <select id="selectVenueById" resultMap="VenueDetailMap">
        SELECT
            v.id,
            v.unit_id,
            v.name,
            v.capacity,
            v.description,
            v.created_at,
            v.updated_at
        FROM venues v
        WHERE v.id = #{id}
    </select>

</mapper>
